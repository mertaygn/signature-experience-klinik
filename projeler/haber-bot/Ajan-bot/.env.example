# ─── Ajan-Bot Environment Variables ──────────────────────────
# Copy this file to .env and fill in your API keys

# Hunter.io — Email finding API
# Get your free API key at: https://hunter.io/api-keys
HUNTER_API_KEY=your_hunter_api_key_here

# Apollo.io — Sales intelligence API (optional)
# Get your API key at: https://app.apollo.io/#/settings/integrations/api
APOLLO_API_KEY=your_apollo_api_key_here

# Telegram Bot — For sending results to Telegram
# Create a bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
